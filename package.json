{
  "name": "ai-translator-helper",
  "version": "1.0.0",
  "description": "AI Customer Service Translator Helper",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "https-proxy-agent": "^9.0.0",
    "lucide-react": "^0.395.0",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.lorstyang.ai-translator-helper",
    "productName": "AI-Translator-Helper",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "src/main/**/*",
      "dist/renderer/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI 客服翻译助手"
    }
  },
  "keywords": [
    "electron",
    "react",
    "translation",
    "openai",
    "ai"
  ],
  "author": "",
  "license": "ISC"
}
